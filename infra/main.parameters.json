{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "resourceGroupName": {
      "value": "rg-grubify-app-${GRUBIFY_RESOURCE_TOKEN}"
    },
    "resourceToken": {
      "value": "${GRUBIFY_RESOURCE_TOKEN}"
    },
    "apiImage": {
      "value": "${SERVICE_API_IMAGE_NAME}"
    },
    "frontendImage": {
      "value": "${SERVICE_FRONTEND_IMAGE_NAME}"
    },
    "existingContainerAppsEnvironmentId": {
      "value": "${AZURE_CONTAINER_APPS_ENVIRONMENT_ID}"
    },
    "sreGithubPatKeyVaultName": {
      "value": "kv-sre-grubify-${GRUBIFY_RESOURCE_TOKEN}"
    },
    "sreGithubPatSecretName": {
      "value": "${SRE_GITHUB_PAT_SECRET_NAME=GH-PAT}"
    },
    "sreAgentExistingSubnetResourceId": {
      "value": "${EXISTING_SRE_AGENT_SUBNET_RESOURCE_ID}"
    },
    "enableSreAgentVnetIntegration": {
      "value": "${ENABLE_SRE_AGENT_VNET_INTEGRATION=false}"
    },
    "sreAgentVnetName": {
      "value": "vnet-sre-agent-${GRUBIFY_RESOURCE_TOKEN}"
    },
    "sreAgentSubnetName": {
      "value": "snet-sre-agent-${GRUBIFY_RESOURCE_TOKEN}"
    },
    "sreAgentNatGatewayName": {
      "value": "nat-sre-agent-${GRUBIFY_RESOURCE_TOKEN}"
    },
    "sreAgentNatPublicIpName": {
      "value": "pip-sre-agent-nat-${GRUBIFY_RESOURCE_TOKEN}"
    },
    "sreAgentVnetAddressPrefix": {
      "value": "${SRE_AGENT_VNET_ADDRESS_PREFIX=10.80.0.0/16}"
    },
    "sreAgentSubnetAddressPrefix": {
      "value": "${SRE_AGENT_SUBNET_ADDRESS_PREFIX=10.80.0.0/24}"
    }
  }
}
